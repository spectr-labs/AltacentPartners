// ===== CALCULATIONS =====
function recalculate() {
  // Must Have
  const allPass = mustHaveState.every(s => s.pass === 'yes');
  const anyFail = mustHaveState.some(s => s.pass === 'no');
  const allAnswered = mustHaveState.every(s => s.pass !== 'unknown');
  const mustHavePass = allPass && allAnswered;

  const mhStatusEl = document.getElementById('musthave-status-text');
  const mhNavBadge = document.getElementById('nav-musthave-badge');
  if (anyFail) {
    mhStatusEl.textContent = '❌ FAILED';
    mhStatusEl.style.color = 'var(--danger)';
    mhNavBadge.textContent = '❌';
    mhNavBadge.className = 'nav-badge badge-fail';
  } else if (allPass && allAnswered) {
    mhStatusEl.textContent = '✅ ALL PASS';
    mhStatusEl.style.color = 'var(--success)';
    mhNavBadge.textContent = '✅';
    mhNavBadge.className = 'nav-badge badge-pass';
  } else {
    mhStatusEl.textContent = '⚠️ INCOMPLETE';
    mhStatusEl.style.color = 'var(--warning)';
    mhNavBadge.textContent = '⚠️';
    mhNavBadge.className = 'nav-badge badge-warn';
  }

  // Preferred Score
  const prefTotalWeight = preferredData.reduce((s, d) => s + d.weight, 0);
  const prefWeightedSum = preferredData.reduce((s, d, i) => s + (preferredState[i].score * d.weight), 0);
  const prefScore = prefTotalWeight > 0 ? prefWeightedSum / prefTotalWeight : 0;
  document.getElementById('preferred-total').textContent = prefScore.toFixed(1);
  document.getElementById('preferred-total').style.color = getColor(prefScore);
  document.getElementById('nav-preferred-score').textContent = prefScore.toFixed(1);

  // Red Flags
  const anyRedFlag = redFlagState.some(s => s.present);
  const rfStatusEl = document.getElementById('redflag-status-text');
  const rfNavBadge = document.getElementById('nav-redflag-badge');
  if (anyRedFlag) {
    rfStatusEl.textContent = '🚩 RED FLAG DETECTED';
    rfStatusEl.style.color = 'var(--danger)';
    rfNavBadge.textContent = '🚩';
    rfNavBadge.className = 'nav-badge badge-fail';
  } else {
    rfStatusEl.textContent = '✅ NO RED FLAGS';
    rfStatusEl.style.color = 'var(--success)';
    rfNavBadge.textContent = '✅';
    rfNavBadge.className = 'nav-badge badge-pass';
  }

  // Fit Score
  const fitTotalWeight = fitData.reduce((s, d) => s + d.weight, 0);
  const fitWeightedSum = fitData.reduce((s, d, i) => s + (fitState[i].score * d.weight), 0);
  const fitScore = fitTotalWeight > 0 ? fitWeightedSum / fitTotalWeight : 0;
  document.getElementById('fit-total').textContent = fitScore.toFixed(1);
  document.getElementById('fit-total').style.color = getColor(fitScore);
  document.getElementById('nav-fit-score').textContent = fitScore.toFixed(1);

  // Psych Score
  const psychTotalWeight = psychData.reduce((s, d) => s + d.weight, 0);
  const psychWeightedSum = psychData.reduce((s, d, i) => s + (psychState[i].strength * d.weight), 0);
  const psychScore = psychTotalWeight > 0 ? psychWeightedSum / psychTotalWeight : 0;
  document.getElementById('psych-total').textContent = psychScore.toFixed(1);
  document.getElementById('psych-total').style.color = getColor(psychScore);
  document.getElementById('nav-psych-score').textContent = psychScore.toFixed(1);

  // Primary driver
  let maxPsychIdx = 0;
  let maxPsychVal = 0;
  psychState.forEach((s, i) => {
    if (s.strength > maxPsychVal) { maxPsychVal = s.strength; maxPsychIdx = i; }
  });
  const primaryDriverEl = document.getElementById('psych-primary-driver');
  if (maxPsychVal > 1) {
    primaryDriverEl.textContent = psychData[maxPsychIdx].name;
    primaryDriverEl.style.color = 'var(--accent)';
  } else {
    primaryDriverEl.textContent = 'Not yet assessed';
    primaryDriverEl.style.color = 'var(--text-muted)';
  }

  // Signals
  const signalCount = signalState.filter(Boolean).length;
  const signalScore = (signalCount / 5) * 10;
  document.getElementById('signals-count').textContent = `${signalCount} of 5`;
  document.getElementById('signals-count').style.color = signalCount >= 3 ? 'var(--success)' : signalCount >= 1 ? 'var(--warning)' : 'var(--text-muted)';
  document.getElementById('nav-signals-count').textContent = `${signalCount}/5`;

  // Composite
  const compositeData = [
    { name: 'Must Have Criteria', score: mustHavePass ? 10 : (anyFail ? 0 : 5), weight: 'GATE', weighted: '-', status: mustHavePass ? '✅ PASS' : (anyFail ? '❌ FAIL' : '⚠️ INCOMPLETE') },
    { name: 'Strongly Preferred', score: prefScore, weight: '25%', weighted: (prefScore * 0.25).toFixed(2), status: prefScore >= 7 ? '✅ Strong' : prefScore >= 4 ? '⚠️ Moderate' : '❌ Weak' },
    { name: 'Fit Dimensions', score: fitScore, weight: '35%', weighted: (fitScore * 0.35).toFixed(2), status: fitScore >= 7 ? '✅ Strong' : fitScore >= 4 ? '⚠️ Moderate' : '❌ Weak' },
    { name: 'Psychological Alignment', score: psychScore, weight: '25%', weighted: (psychScore * 0.25).toFixed(2), status: psychScore >= 7 ? '✅ Strong' : psychScore >= 4 ? '⚠️ Moderate' : '❌ Weak' },
    { name: 'Positive Signals', score: signalScore, weight: '15%', weighted: (signalScore * 0.15).toFixed(2), status: signalScore >= 60 ? '✅ Strong' : signalScore >= 30 ? '⚠️ Moderate' : '❌ Weak' },
  ];

  const compTbody = document.getElementById('composite-tbody');
  compTbody.innerHTML = compositeData.map(row => `
    <tr>
      <td style="font-weight:600;">${row.name}</td>
      <td style="font-family:'JetBrains Mono',monospace; font-weight:700;">${typeof row.score === 'number' ? row.score.toFixed(1) : row.score}</td>
      <td><span class="weight-tag">${row.weight}</span></td>
      <td style="font-family:'JetBrains Mono',monospace;">${row.weighted}</td>
      <td><span class="status-badge ${row.status.includes('PASS') || row.status.includes('Strong') ? 'status-pass' : row.status.includes('FAIL') || row.status.includes('Weak') ? 'status-fail' : 'status-unknown'}">${row.status}</span></td>
    </tr>
  `).join('');

  // Final Score (only if must-have passes and no red flags)
  let finalScore = 0;
  let canScore = mustHavePass && !anyRedFlag;
  if (canScore) {
    finalScore = (prefScore * 0.25) + (fitScore * 0.35) + (psychScore * 0.25) + (signalScore * 0.15);
  }

  const finalEl = document.getElementById('final-score-display');
  finalEl.textContent = finalScore.toFixed(1);
  finalEl.style.color = canScore ? getColor(finalScore) : 'var(--text-muted)';

  const badgeEl = document.getElementById('final-score-badge');
  if (!canScore) {
    if (anyFail || anyRedFlag) {
      badgeEl.textContent = 'DISQUALIFIED';
      badgeEl.className = 'status-badge status-fail';
    } else {
      badgeEl.textContent = 'NOT RECOMMENDED';
      badgeEl.className = 'status-badge status-unknown';
    }
  } else if (finalScore >= 7.5) {
    badgeEl.textContent = '⭐ HIGHLY RECOMMENDED';
    badgeEl.className = 'status-badge status-pass';
  } else if (finalScore >= 5.5) {
    badgeEl.textContent = '✅ RECOMMENDED';
    badgeEl.className = 'status-badge status-pass';
  } else if (finalScore >= 4.0) {
    badgeEl.textContent = '⚠️ PROCEED WITH CAUTION';
    badgeEl.className = 'status-badge status-unknown';
  } else {
    badgeEl.textContent = '❌ NOT RECOMMENDED';
    badgeEl.className = 'status-badge status-fail';
  }

  // Sidebar
  const sidebarScore = document.getElementById('sidebar-final-score');
  const sidebarBar = document.getElementById('sidebar-score-bar');
  const sidebarDecision = document.getElementById('sidebar-decision');

  if (canScore) {
    sidebarScore.textContent = finalScore.toFixed(1);
    sidebarScore.style.color = getColor(finalScore);
    sidebarBar.style.width = (finalScore * 10) + '%';
    sidebarBar.style.background = getColor(finalScore);
  } else {
    sidebarScore.textContent = '—';
    sidebarScore.style.color = 'var(--text-muted)';
    sidebarBar.style.width = '0%';
  }

  // Decision
  updateDecision(finalScore, mustHavePass, anyFail, anyRedFlag, canScore);
  updateReachOut();
}

function recalculatePostMeeting() {
  const pmAvg = postMeetingState.reduce((s, v) => s + v, 0) / postMeetingState.length;
  document.getElementById('postmeeting-total').textContent = pmAvg.toFixed(1);
  document.getElementById('postmeeting-total').style.color = getColor(pmAvg);

  const assessEl = document.getElementById('postmeeting-assessment');
  if (pmAvg >= 7) {
    assessEl.textContent = '✅ PROCEED - Strong meeting, advance to next stage';
    assessEl.style.color = 'var(--success)';
  } else if (pmAvg >= 5) {
    assessEl.textContent = '⚠️ CONDITIONAL PROCEED - Some concerns, needs follow-up';
    assessEl.style.color = 'var(--warning)';
  } else {
    assessEl.textContent = '🚫 PAUSE - Meeting suggests poor fit, needs review';
    assessEl.style.color = 'var(--danger)';
  }
}

function recalculateResearch() {
  const count = researchState.filter(s => s.checked).length;
  const el = document.getElementById('research-count');
  el.textContent = `${count} of 9 sources checked`;
  el.style.color = count >= 7 ? 'var(--success)' : count >= 4 ? 'var(--warning)' : 'var(--text-muted)';
  document.getElementById('nav-research-count').textContent = `${count}/9`;
}

function updateDecision(finalScore, mustHavePass, anyFail, anyRedFlag, canScore) {
  const box = document.getElementById('decision-box');
  const icon = document.getElementById('decision-icon');
  const text = document.getElementById('decision-text');
  const sub = document.getElementById('decision-sub');
  const proceed = document.getElementById('decision-proceed');
  const action = document.getElementById('decision-action');
  const template = document.getElementById('decision-template');
  const priority = document.getElementById('decision-priority');
  const confidence = document.getElementById('decision-confidence');
  const sidebarDec = document.getElementById('sidebar-decision');

  if (anyFail || anyRedFlag) {
    box.className = 'decision-box reject';
    icon.textContent = '🚫';
    text.textContent = 'DO NOT PROCEED';
    sub.textContent = anyRedFlag ? 'Red flag detected — candidate disqualified' : 'Must-have criteria not met';
    proceed.textContent = '🚫 DO NOT PROCEED';
    proceed.style.color = 'var(--danger)';
    action.textContent = 'Archive as not a fit';
    template.textContent = '—';
    priority.textContent = '⚪ ARCHIVE';
    confidence.textContent = '🟢 HIGH - Clear disqualification';
    sidebarDec.textContent = '🚫 DO NOT PROCEED';
    sidebarDec.style.background = 'var(--danger-bg)';
    sidebarDec.style.color = 'var(--danger)';
  } else if (!mustHavePass) {
    box.className = 'decision-box pause';
    icon.textContent = '⏳';
    text.textContent = 'INCOMPLETE ASSESSMENT';
    sub.textContent = 'Complete all must-have criteria before decision';
    proceed.textContent = '⏳ AWAITING DATA';
    proceed.style.color = 'var(--warning)';
    action.textContent = 'Complete research';
    template.textContent = '—';
    priority.textContent = '🟡 PENDING';
    confidence.textContent = '🔴 LOW - Too many unknowns';
    sidebarDec.textContent = '⏳ INCOMPLETE';
    sidebarDec.style.background = 'var(--warning-bg)';
    sidebarDec.style.color = 'var(--warning)';
  } else if (finalScore >= 7.5) {
    box.className = 'decision-box proceed';
    icon.textContent = '🌟';
    text.textContent = 'STRONG PROCEED - Excellent fit for Altacent model';
    sub.textContent = 'High alignment across all dimensions. Prioritize outreach.';
    proceed.textContent = '✅ PROCEED - High Priority';
    proceed.style.color = 'var(--success)';
    action.textContent = 'Immediate personalized outreach';
    template.textContent = 'Partner Vision template (Template 1)';
    priority.textContent = '🔴 HIGH PRIORITY';
    confidence.textContent = '🟢 HIGH - Strong data alignment';
    sidebarDec.textContent = '✅ PROCEED';
    sidebarDec.style.background = 'var(--success-bg)';
    sidebarDec.style.color = 'var(--success)';
  } else if (finalScore >= 5.5) {
    box.className = 'decision-box proceed';
    icon.textContent = '✅';
    text.textContent = 'PROCEED - Good fit, worth pursuing';
    sub.textContent = 'Solid alignment with some areas to explore further.';
    proceed.textContent = '✅ PROCEED';
    proceed.style.color = 'var(--success)';
    action.textContent = 'Schedule exploratory conversation';
    template.textContent = 'Partner Test template (Template 3)';
    priority.textContent = '🟡 MEDIUM PRIORITY';
    confidence.textContent = '🟡 MEDIUM - Good indicators';
    sidebarDec.textContent = '✅ PROCEED';
    sidebarDec.style.background = 'var(--success-bg)';
    sidebarDec.style.color = 'var(--success)';
  } else if (finalScore >= 4.0) {
    box.className = 'decision-box pause';
    icon.textContent = '⚠️';
    text.textContent = 'CONDITIONAL PROCEED - Marginal fit';
    sub.textContent = 'Some alignment but significant gaps. Needs deeper exploration.';
    proceed.textContent = '⚠️ CONDITIONAL';
    proceed.style.color = 'var(--warning)';
    action.textContent = 'Limited outreach, gather more data';
    template.textContent = 'Soft Touch template (Template 4)';
    priority.textContent = '🟡 LOW PRIORITY';
    confidence.textContent = '🟡 MEDIUM - Mixed signals';
    sidebarDec.textContent = '⚠️ CONDITIONAL';
    sidebarDec.style.background = 'var(--warning-bg)';
    sidebarDec.style.color = 'var(--warning)';
  } else {
    box.className = 'decision-box reject';
    icon.textContent = '🚫';
    text.textContent = 'DO NOT PROCEED - Poor fit for Altacent model';
    sub.textContent = 'Low alignment across key dimensions.';
    proceed.textContent = '🚫 DO NOT PROCEED';
    proceed.style.color = 'var(--danger)';
    action.textContent = 'Archive as not a fit';
    template.textContent = '—';
    priority.textContent = '⚪ ARCHIVE';
    confidence.textContent = '🔴 LOW - Too many unknowns, need more research';
    sidebarDec.textContent = '🚫 DO NOT PROCEED';
    sidebarDec.style.background = 'var(--danger-bg)';
    sidebarDec.style.color = 'var(--danger)';
  }
}

