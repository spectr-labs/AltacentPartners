      Awaiting Assessment
    </div>
  </div>
</aside>

<!-- MAIN CONTENT -->
<main class="main">

<!-- SECTION: PRIMARY INPUTS -->
<div class="section active" id="sec-inputs">
  <div class="section-header">
    <h2>📋 Primary Inputs</h2>
    <p>Enter the candidate's basic information to begin the qualification process.</p>
  </div>

  <div class="howto-banner">
    <h3>HOW TO USE</h3>
    <ol>
      <li>Enter <strong>PRIMARY INPUTS</strong> (LinkedIn URL, Email)</li>
      <li>Fill <strong>PROFILE DATA</strong> from research</li>
      <li>Review auto-calculated <strong>SCORES</strong></li>
      <li>Check <strong>DECISION & NEXT ACTIONS</strong></li>
    </ol>
  </div>

  <div class="card">
    <div class="card-title">━━━ PRIMARY INPUTS ━━━</div>
    <div class="form-grid">
      <div class="form-group">
        <label class="form-label">Candidate Name</label>
        <input type="text" class="form-input" id="candidate-name" placeholder="Enter full name as appears on LinkedIn">
      </div>
      <div class="form-group">
        <label class="form-label">Assessment Date</label>
        <input type="date" class="form-input" id="assessment-date">
      </div>
      <div class="form-group">
        <label class="form-label">LinkedIn URL</label>
        <input type="url" class="form-input" id="linkedin-url" placeholder="https://linkedin.com/in/...">
      </div>
